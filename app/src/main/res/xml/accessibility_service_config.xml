<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility Service Configuration
    =====================================
    This file configures what events the accessibility service listens to.

    accessibilityEventTypes:
        TYPE_TOUCH_INTERACTION_START / END — fired at the start and end of
        every touch gesture anywhere on the device.

    accessibilityFeedbackType:
        FEEDBACK_GENERIC — we do not provide screen-reader feedback; we only
        intercept events to count taps.

    flags:
        FLAG_RETRIEVE_INTERACTIVE_WINDOWS — allows the service to query which
        windows are currently on screen (useful for future enhancements).
        FLAG_REQUEST_TOUCH_EXPLORATION_MODE is intentionally omitted because
        we must NOT change how touches behave for the user — we are passive.

    notificationTimeout:
        300ms — how long Android waits before sending another batch of events.
        Lower = more responsive tap detection; 300ms is a good balance.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeAllMask"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows|flagRequestFilterKeyEvents"
    android:canPerformGestures="false"
    android:canRetrieveWindowContent="false"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="300"
    android:settingsActivity="com.minthitsaraung.personalaiagent.ui.activity.SettingsActivity" />
